{
	"name": "df_flattenValue",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_adls_json_gp",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "flatten1"
				},
				{
					"name": "aggregate1"
				},
				{
					"name": "surrogateKey1"
				},
				{
					"name": "rank1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id as integer,",
				"          name as string,",
				"          email as string,",
				"          roles as string[]",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     documentForm: 'arrayOfDocuments') ~> source1",
				"source1 foldDown(unroll(roles, roles),",
				"     mapColumn(",
				"          id,",
				"          name,",
				"          email,",
				"          roles",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> flatten1",
				"rank1 aggregate(groupBy(name,",
				"          id,",
				"          email,",
				"          rnk_nbr),",
				"     roles = collect(roles)) ~> aggregate1",
				"flatten1 keyGenerate(output(SrKey as long),",
				"     startAt: 100L,",
				"     stepValue: 2L) ~> surrogateKey1",
				"surrogateKey1 rank(asc(name, true),",
				"     output(rnk_nbr as long),",
				"     dense: true) ~> rank1"
			]
		}
	}
}